# ============================================================
# Suproval — Partes de Taller
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# --- Supabase ---
# Los encuentras en tu proyecto de Supabase:
#   Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
#   Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Clave de servicio (service_role). SOLO se usa en el servidor
# para tareas de administración (crear/gestionar usuarios).
# NUNCA la expongas en el cliente ni la subas al repositorio.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Integración con Make (webhook) ---
# URL del webhook de Make al que se envían los partes al crear/actualizar
MAKE_WEBHOOK_URL=https://hook.eu1.make.com/g3y641mo6f9r1ekdqix0k2t9s9bouypr
